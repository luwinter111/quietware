{
  "name": "quietware",
  "version": "0.0.1",
  "private": true,
  "description": "Quietware — 一套引擎,养一窝「不被打扰」的开源替代产品。Open-source, ad-free alternatives powered by a shared AI feed engine.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "core:demo": "pnpm --filter @quietware/core demo",
    "reader:dev": "pnpm --filter @quietware/reader dev",
    "podcast:dev": "pnpm --filter @quietware/podcast dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
